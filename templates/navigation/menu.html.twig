{#
/**
 * @file
 * Menu — rendered as a vertical, right-aligned list (the primary site nav).
 * Active link uses ink + semibold; the rest are muted with a hover transition.
 * The top-level list carries schema.org SiteNavigationElement.
 *
 * @ingroup themeable
 */
#}
{% import _self as menus %}

{% macro menu_links(items, depth) %}
  {% import _self as menus %}
  {% if items %}
    {% if depth == 0 %}
      <ul class="flex flex-col gap-2 text-right text-base" itemscope itemtype="https://schema.org/SiteNavigationElement">
    {% else %}
      <ul class="mt-2 flex flex-col gap-1 text-right text-sm">
    {% endif %}
      {% for item in items %}
        <li>
          {% if item.url.isRouted and item.url.routeName == '<nolink>' %}
            <span>{{ item.title }}</span>
          {% else %}
            <a href="{{ item.url }}" itemprop="url"
               class="transition-colors {{ item.in_active_trail ? 'font-semibold text-ink' : 'text-muted hover:text-ink' }}"
               {% if item.in_active_trail %}aria-current="page"{% endif %}>
              <span itemprop="name">{{- item.title -}}</span>
            </a>
          {% endif %}
          {% if item.below %}
            {{ menus.menu_links(item.below, depth + 1) }}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{{ menus.menu_links(items, 0) }}

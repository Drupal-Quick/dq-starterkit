{#
/**
 * @file
 * Main page layout — embeds the page shell
 * (templates/includes/page-shell.html.twig; the arrangement baked there at
 * scaffold time) and supplies the interior-page main content: breadcrumb,
 * status, help, then the content region.
 *
 * @see template_preprocess_page()
 * @ingroup themeable
 */
#}
{% embed '@dq_starterkit/includes/page-shell.html.twig' %}
  {% block main %}
    {% if page.breadcrumb %}{{ page.breadcrumb }}{% endif %}
    {% if page.highlighted %}
      <div role="status" aria-live="polite">{{ page.highlighted }}</div>
    {% endif %}
    {% if page.help %}{{ page.help }}{% endif %}
    {{ page.content }}
  {% endblock %}
{% endembed %}

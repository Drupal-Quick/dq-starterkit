{#
/**
 * @file
 * Front-page layout — embeds the page shell
 * (templates/includes/page-shell.html.twig) trimmed to just the content
 * region, so the homepage is only the navigation plus the front view or the
 * composed homepage blocks.
 *
 * @see page.html.twig
 * @ingroup themeable
 */
#}
{% embed '@dq_starterkit/includes/page-shell.html.twig' %}
  {% block main %}
    {{ page.content }}
  {% endblock %}
{% endembed %}
